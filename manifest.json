{
  "manifest_version": 3,
  "name": "打开新标签页",
  "version": "1.0.0",
  "description": "点击扩展图标显示网站列表，快速打开常用网站",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_title": "打开新标签页",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon_16x16.png",
    "32": "icons/icon_32x32.png",
    "48": "icons/icon_48x48.png",
    "128": "icons/icon_128x128.png"
  }
}
